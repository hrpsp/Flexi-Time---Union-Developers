# ── Database (NeonDB serverless PostgreSQL) ──────────────────────────────────
# Get both from: https://console.neon.tech → your project → Connection Details
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"
# Non-pooled URL required for Prisma Migrate (use "Pooler" mode OFF in Neon)
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"

# ── NextAuth v5 ───────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET="your-super-secret-minimum-32-char-string"
NEXTAUTH_URL="http://localhost:3000"

# ── Email / SMTP (Phase 5 — Nodemailer) ──────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="noreply@flexiit.com"
SMTP_PASS="your-app-specific-password"
SMTP_FROM="Flexi Time <noreply@flexiit.com>"
