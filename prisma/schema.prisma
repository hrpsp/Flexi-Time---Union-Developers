generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
  HR_MANAGER
  HR_EXECUTIVE
  VIEWER
}

enum AttendanceStatus {
  PRESENT
  SHORT_TIME
  HALF_DAY
  ABSENT
  MISSING_IN
  MISSING_OUT
  LEAVE
  UNMARKED
  OFF
}

enum LeaveType {
  ANNUAL
  SICK
  CASUAL
  EMERGENCY
  UNPAID
  WORK_FROM_HOME
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
}

enum Gender {
  MALE
  FEMALE
}

enum MaritalStatus {
  MARRIED
  UN_MARRIED
}

enum BloodGroup {
  A_POS
  A_NEG
  B_POS
  B_NEG
  O_POS
  O_NEG
  AB_POS
  AB_NEG
}

enum Religion {
  ISLAM
  CHRISTIAN
  OTHER
}

enum Division {
  SUPPORT_SERVICES
  INFRASTRUCTURE
  CONSTRUCTION
  COMMERCIAL
}

// ─────────────────────────────────────────────────────────────────────────────
// MODELS
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(VIEWER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  overrides  AttendanceRecord[] @relation("OverriddenBy")
  auditLogs  AuditLog[]

  @@map("users")
}

model Department {
  id        String     @id @default(cuid())
  code      Int        @unique
  name      String
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())

  employees Employee[]

  @@map("departments")
}

model Employee {
  id   String @id @default(cuid())

  // ── Identifiers ──────────────────────────────────────────────────────────
  hcmId             String         @unique
  cnic              String?        @unique

  // ── Personal Info ─────────────────────────────────────────────────────────
  name              String
  fatherName        String?
  gender            Gender?
  dateOfBirth       DateTime?
  maritalStatus     MaritalStatus?
  bloodGroup        BloodGroup?
  religion          Religion?
  education         String?
  contactNumber     String?
  email             String?
  address           String?

  // ── Emergency / NOK ───────────────────────────────────────────────────────
  nokName           String?
  nokRelation       String?
  emergencyContact  String?

  // ── Employment Details ─────────────────────────────────────────────────────
  designation       String?
  grade             String?
  pgcGrade          String?
  doj               DateTime?
  confirmationDate  DateTime?
  division          Division?
  project           String?

  // ── CNIC Validity ──────────────────────────────────────────────────────────
  cnicIssueDate     DateTime?
  cnicExpiryDate    DateTime?

  // ── Org Structure ──────────────────────────────────────────────────────────
  departmentId      String
  subDepartment     String?

  // ── Status ─────────────────────────────────────────────────────────────────
  status            EmployeeStatus @default(ACTIVE)
  dol               DateTime?
  rejoiningDate     DateTime?

  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  department        Department              @relation(fields: [departmentId], references: [id])
  attendance        AttendanceRecord[]
  statusHistory     EmployeeStatusHistory[]

  @@map("employees")
}

model EmployeeStatusHistory {
  id            String         @id @default(cuid())
  employeeId    String
  status        EmployeeStatus
  effectiveDate DateTime
  reason        String?
  createdAt     DateTime       @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])

  @@map("employee_status_history")
}

model AttendancePeriod {
  id        String   @id @default(cuid())
  label     String
  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())

  records AttendanceRecord[]

  @@map("attendance_periods")
}

model AttendanceRecord {
  id               String            @id @default(cuid())
  employeeId       String
  periodId         String
  date             DateTime          @db.Date
  inTime           String?
  outTime          String?
  workedMinutes    Int?
  calculatedStatus AttendanceStatus
  overriddenStatus AttendanceStatus?
  leaveType        LeaveType?
  note             String?
  overriddenById   String?
  overriddenAt     DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  employee     Employee         @relation(fields: [employeeId], references: [id])
  period       AttendancePeriod @relation(fields: [periodId], references: [id])
  overriddenBy User?            @relation("OverriddenBy", fields: [overriddenById], references: [id])

  @@unique([employeeId, date])
  @@map("attendance_records")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  entityType String
  entityId   String
  before     Json?
  after      Json?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model EmailTemplate {
  id        String   @id @default(cuid())
  key       String   @unique
  subject   String
  htmlBody  String   @db.Text
  variables String[]
  updatedAt DateTime @updatedAt

  @@map("email_templates")
}

model ShiftConfig {
  id             String  @id @default(cuid())
  name           String
  startTime      String
  endTime        String
  graceMinutes   Int     @default(15)
  presentMinutes Int     @default(465)
  shortTimeMin   Int     @default(391)
  halfDayMin     Int     @default(240)
  isDefault      Boolean @default(false)

  @@map("shift_configs")
}
